# Copy this file to ~/.x-tweetcraft.env and fill in your actual credentials.
# Get these from https://developer.x.com/en/portal/dashboard after creating an App.
# See skills/x-connect-api/references/detailed-setup-guide.md for step-by-step.

X_BEARER_TOKEN=your_bearer_token_here
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_key_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
